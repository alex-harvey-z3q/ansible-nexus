---
extends: default

rules:
  braces:
    max-spaces-inside: 1
  line-length:
    max: 120
    level: warning
  comments-indentation: false
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
  truthy:
    allowed-values:
      - "true"
      - "false"
  comments:
    min-spaces-from-content: 1
